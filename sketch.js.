let tankImg;

function preload() {
  // ВАЖНО: без ./ 
  tankImg = loadImage('tank.png');
}

function setup() {
  createCanvas(windowWidth, windowHeight);
  imageMode(CENTER);
}

function draw() {
  background(0);

  // Проверка загрузки
  if (tankImg) {
    image(tankImg, width / 2, height / 2, 200, 200);
  } else {
    // Если не загрузилось — увидишь это
    fill(255);
    textSize(20);
    text("IMG NOT LOADED", 20, 40);
  }
}

function windowResized() {
  resizeCanvas(windowWidth, windowHeight);
}
